#!/bin/bash
set -euo pipefail

# Change to the script's directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Set variables for Obsidian to Hugo copy
sourcePath="/home/david/obsidian-vault/posts/"
destinationPath="/home/david/dwo.sh/content/posts/"

# Check for required commands
for cmd in git rsync python3 hugo; do
    if ! command -v $cmd &> /dev/null; then
        echo "$cmd is not installed or not in PATH."
        exit 1
    fi
done

# Step 1: Sync posts from Obsidian to Hugo content folder using rsync
echo "Syncing posts from Obsidian..."

if [ ! -d "$sourcePath" ]; then
    echo "Source path does not exist: $sourcePath"
    exit 1
fi

if [ ! -d "$destinationPath" ]; then
    echo "Destination path does not exist: $destinationPath"
    exit 1
fi

rsync -av --delete "$sourcePath" "$destinationPath"

# Step 2: Process Markdown files with Python script to handle image links
echo "Processing image links in Markdown files..."
if [ ! -f "images-linux.py" ]; then
    echo "Python script images.py not found."
    exit 1
fi

if ! python3 images-linux.py; then
    echo "Failed to process image links."
    exit 1
fi

# Step 3: make sure the public submodule is initialized
echo "Initializing public submodule if needed..."
if [ ! -f "public/.git" ] && [ ! -d "public/.git" ]; then
    if ! git submodule update --init --recursive public; then
        echo "Failed to initialize public submodule."
        exit 1
    fi
fi

# Step 4: Build the Hugo site
echo "Building the Hugo site..."
if ! hugo; then
    echo "Hugo build failed."
    exit 1
fi

# Step 5: cd into the public folder
echo "Changing directory to public"
cd public

# Step 6: Add changes to Git
echo "Staging changes for Git..."
git add -A

# Step 7: Commit changes with a dynamic message
commit_message="Blog update on $(date +'%Y-%m-%d %H:%M:%S')"
if git diff --cached --quiet; then
    echo "No changes to commit."
else
    echo "Committing changes..."
    git commit -m "$commit_message"
fi

# Step 8: Push all changes to the main branch
echo "Deploying to GitHub Main..."
if ! git push origin HEAD:main; then
    echo "Failed to push to main branch."
    exit 1
fi

# Step 9: cd back
echo "Changing directory to original"
cd ..

# Step 10: Commit and push source repository changes
echo "Staging source repository changes..."
if git diff --quiet && git diff --cached --quiet && git ls-files --others --exclude-standard | grep -q '^'; then
    # We also check for untracked files with ls-files, but wrapping it all simply with 'git status --porcelain' is easier.
    # Let's simplify the diff check.
fi

# A better check for changes in the source repo
if [ -z "$(git status --porcelain)" ]; then
    echo "No changes in source repository to stage."
else
    git add .
    echo "Committing source repository changes..."
    git commit -m "$commit_message"
    echo "Pushing source repository to GitHub..."
    if ! git push origin main; then
        echo "Failed to push source repository."
        exit 1
    fi
fi

echo "All done! Site synced, processed, committed, built, and deployed."
